{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-native",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "@matjip/shared": ["../../packages/shared/src/types/index.ts"],
      "@matjip/shared/*": ["../../packages/shared/src/*"],
      "@/*": ["./src/*"]
